{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(git init:*)",
      "Bash(git remote:*)",
      "Bash(touch .gitkeep)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git push:*)",
      "Bash(git config:*)",
      "Bash(git credential:*)",
      "Bash(mkdir -p ~/.git)",
      "Bash(~/.git-credentials)",
      "Bash(git --version)"
    ]
  }
}
